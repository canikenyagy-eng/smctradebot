# Phase 3.3 RC veto shadow-live example.
# Copy these values into .env to observe the RC veto without blocking Telegram signals.

# Keep real live blocking OFF.
ENABLE_PRE_TRADE_FILTER=0

# Enable shadow logging only.
ENABLE_PRE_TRADE_FILTER_SHADOW=1
PRE_TRADE_FILTER_SHADOW_LOG_PATH=logs/pre_trade_filter_shadow.jsonl

# RC rule under observation: block EXPANSION + continuation in shadow only.
PRE_TRADE_BLOCK_EXPANSION_CONTINUATION=1
PRE_TRADE_BLOCK_EXPANSION_CONTINUATION_FALLBACK=0
